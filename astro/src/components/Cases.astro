---
const cases = [
  {
    num: "01",
    tag: "Реверс-инжиниринг",
    title:
      "Производство детали и выпуск КД с использованием реверс-инжиниринга",
    img: "/assets/case-1.png",
    rows: [
      {
        label: "Задача",
        text: "Высокая стоимость закупки, не устраивают сроки поставки из-за рубежа, запрос на локализацию производства детали",
      },
      {
        label: "Решение",
        text: "Освоенная технология производства серии с оптимизацией стоимости на 85% в сравнении с китайским производителем",
      },
    ],
  },
  {
    num: "02",
    tag: "Аддитивное производство",
    title: "Пресс-форма с конформным охлаждением",
    img: "/assets/case-2.png",
    rows: [
      {
        label: "Задача",
        text: "Потребность в оптимизации сроков поставки пресс-форм из-за рубежа, оптимизации стоимости, создании устойчивого партнерства с отечественными производителями специальной оснастки под термовакуумную формовку",
      },
      {
        label: "Решение",
        text: "Проектирование и разработка пресс-формы с уникальной системой каналов охлаждения с ускоренным втрое циклом формования изделия в отличие от традиционной технологии. Импортозамещение с сокращением сроков и стоимости производства.",
      },
    ],
  },
  {
    num: "03",
    tag: "Авиация / БПЛА",
    title: "Оснастка для отливки винта БПЛА самолетного типа",
    img: "/assets/case-3.png",
    rows: [
      {
        label: "Задача",
        text: "Поставка на предприятие винтов большого диаметра из угленаполненного пластика",
      },
      {
        label: "Решение",
        text: "Проектирование оснастки с каскадной системой литья для обеспечения проливаемости вязким материалом большого диаметра детали",
      },
    ],
  },
  {
    num: "04",
    tag: "Импортозамещение / Пищепром",
    title:
      "Импортозамещение пластиковых поршней для производства детской молочной продукции",
    img: "/assets/case-4.png",
    rows: [
      {
        label: "Задача",
        text: "Потребность в импортозамещении пластиковых поршней для производства детской молочной продукции",
      },
      {
        label: "Решение",
        text: "Разработка оснастки и технологии производства наиболее выгодной по стоимости для мелкой серии с учетом сложности геометрии деталей",
      },
    ],
  },
];
---

<section class="c2" id="projects">
  <div class="c2-hdr">
    <h2 class="c2-title">КЕЙСЫ</h2>
    <div class="c2-nav" id="c2nav">
      {
        cases.map((_, i) => (
          <div
            class={`c2-dot${i === 0 ? " active" : ""}`}
            onclick={`c2Go(${i})`}
          />
        ))
      }
    </div>
  </div>

  <div class="c2-scroll" id="c2scroll">
    {
      cases.map(({ num, tag, title, img, rows }) => (
        <div class="c2-slide">
          <div class="c2-img-col">
            <img src={img} alt="" class="img-smooth" />
            <div class="c2-num">{num}</div>
          </div>
          <div class="c2-content">
            <div class="c2-tag">{tag}</div>
            <div class="c2-case-title">{title}</div>
            <div class="c2-divider" />
            <div class="c2-row">
              {rows.map(({ label, text }) => (
                <>
                  <div class="c2-row-lbl">{label}</div>
                  <div class="c2-row-text">{text}</div>
                </>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="c2-progress">
    <div class="c2-progress-bar" id="c2bar"></div>
  </div>
</section>

<style>
  .c2 {
    position: relative;
    z-index: 6;
    background: #0a0a0a;
    border-bottom: 2px solid #1a1a1a;
    height: calc(100svh - 64px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .c2-hdr {
    padding: clamp(20px, 3.5vh, 40px) var(--pad) clamp(12px, 2vh, 24px);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-shrink: 0;
  }
  .c2-title {
    font-family: var(--fd);
    font-weight: 900;
    font-size: clamp(52px, 7vw, 108px);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.9;
    color: #fff;
  }
  .c2-nav {
    display: flex;
    gap: 8px;
    align-items: center;
    padding-bottom: 8px;
  }
  .c2-dot {
    width: 32px;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    cursor: pointer;
    transition:
      background 0.067s,
      width 0.1s;
  }
  .c2-dot.active {
    background: var(--orange);
    width: 56px;
  }
  .c2-scroll {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    flex: 1;
    min-height: 0;
  }
  .c2-scroll::-webkit-scrollbar {
    display: none;
  }
  .c2-scroll:active {
    cursor: grabbing;
  }
  .c2-slide {
    flex: 0 0 100vw;
    scroll-snap-align: start;
    height: 100%;
    padding: 0 var(--pad) clamp(24px, 4vh, 48px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }
  .c2-img-col {
    position: relative;
    display: flex;
    align-items: flex-end;
    height: 100%;
  }
  .c2-img-col img {
    position: absolute;
    inset: clamp(8px, 1.5vh, 20px) 0;
    object-fit: contain;
    opacity: 0;
    mix-blend-mode: luminosity;
    transition: opacity 0.55s var(--ease);
  }
  .c2-img-col img.is-loaded {
    opacity: 0.45;
  }
  .c2-num {
    position: relative;
    z-index: 1;
    font-family: var(--fd);
    font-weight: 1000;
    font-size: clamp(120px, 20vw, 280px);
    letter-spacing: 0em;
    line-height: 1;
    color: #fff;
    user-select: none;
  }
  .c2-content {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vh, 36px);
  }
  .c2-tag {
    font-family: var(--fd);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--orange);
  }
  .c2-case-title {
    font-family: var(--fd);
    font-weight: 800;
    font-size: clamp(22px, 2.8vw, 38px);
    color: #fff;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .c2-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }
  .c2-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px 24px;
  }
  .c2-row-lbl {
    font-family: var(--fd);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    padding-top: 3px;
    white-space: nowrap;
  }
  .c2-row-text {
    font-family: var(--fs);
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
  }
  .c2-progress {
    height: 2px;
    background: #1a1a1a;
    margin: 0 var(--pad);
    flex-shrink: 0;
  }
  .c2-progress-bar {
    height: 100%;
    background: var(--orange);
    width: 25%;
    transition: width 0.2s var(--ease);
  }

  @media (max-width: 900px) {
    .c2 {
      height: auto;
      min-height: calc(100svh - 64px);
    }
    .c2-scroll {
      touch-action: pan-y pinch-zoom;
      overscroll-behavior-x: contain;
    }
    .c2-slide {
      grid-template-columns: 1fr;
      height: auto;
      scroll-snap-stop: always;
    }
    .c2-img-col {
      height: clamp(200px, 35vw, 360px);
    }
    .c2-num {
      font-size: clamp(80px, 18vw, 160px);
    }
  }
</style>
