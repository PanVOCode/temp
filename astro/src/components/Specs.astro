---
const specs = [
  { k: "материал", v: "под Вашу задачу" },
  { k: "гнезд", v: "1 — 80" },
  { k: "ресурс", v: "до 1 000 000 смыканий" },
  { k: "точность", v: "±0.01 мм · IT6–IT7" },
  { k: "габариты", v: "любая геометрия" },
  { k: "тип литья", v: "горячеканальное/холодноканальное/каскадное" },
  { k: "охлаждение", v: "прямоточное/конформное" },
];
---

<section class="specs" id="specs">
  <div class="specs-l">
    <span class="eyebrow reveal">03 / технические параметры</span>
    <div class="specs-title reveal d1">ТЕХНИЧЕСКИЕ ПАРАМЕТРЫ</div>
    <div>
      {
        specs.map(({ k, v }, i) => (
          <div
            class={`spec-row reveal${i > 0 && i < 5 ? ` d${i}` : i >= 5 ? " d4" : ""}`}
          >
            <span class="spec-k">{k}</span>
            <span class="spec-v">{v}</span>
          </div>
        ))
      }
    </div>
    <a href="#cta" class="btn btn-black reveal" style="margin-top:32px">
      Запросить расчёт формы под изделие
      <svg
        width="11"
        height="11"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
      >
    </a>
  </div>
</section>

<style>
  .specs {
    position: relative;
    z-index: 5;
    display: flex;
    border-bottom: 1px solid #000;
    min-height: 100svh;
    width: 100%;
    overflow-x: clip;
    --pad: clamp(24px, max(5vw, 50vw - 560px), 400px);
  }
  .specs-l {
    padding: clamp(48px, 8vh, 80px) var(--pad);
    background: var(--paper);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    flex: 1;
    min-width: 0;
    width: 100%;
    box-sizing: border-box;
    min-height: 100svh;
  }
  .specs-title {
    font-family: var(--fd);
    font-weight: 900;
    font-size: var(--type-display-sm);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #000;
    line-height: 0.92;
    margin: clamp(16px, min(2vw, 3svh), 28px) 0 clamp(20px, min(2.5vw, 3.5svh), 36px);
    max-width: 100%;
    overflow-wrap: anywhere;
  }
  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 11px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    gap: 16px;
    min-width: 0;
  }
  .spec-k {
    font-size: var(--type-caption);
    font-weight: 400;
    letter-spacing: 0.18em;
    color: var(--grey-40);
    flex: 0 0 auto;
  }
  .spec-v {
    font-size: var(--type-body-lg);
    font-weight: 500;
    color: #000;
    text-align: right;
    min-width: 0;
    flex: 1 1 50%;
    overflow-wrap: anywhere;
  }
  .specs-l .btn {
    align-self: flex-start;
    max-width: 100%;
    white-space: normal;
    line-height: 1.35;
  }

  @media (min-width: 1301px) and (min-height: 920px) {
    .specs-l {
      justify-content: center;
      justify-content: safe center;
    }
  }

  @media (max-width: 1300px) {
    .specs-l {
      justify-content: flex-start;
      padding-top: clamp(40px, 7vh, 64px);
      padding-bottom: clamp(40px, 7vh, 64px);
    }
    .specs-title {
      font-size: var(--type-heading);
      margin: 16px 0 20px;
    }
    .spec-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      padding: 8px 0;
    }
    .spec-v {
      width: 100%;
      text-align: left;
      font-size: var(--type-body-lg);
    }
  }
  @media (max-width: 767px) {
    .specs {
      min-height: auto;
    }
    .specs-l {
      min-height: auto;
      padding: 40px var(--pad) 48px;
    }
    .specs-title {
      font-size: clamp(36px, 10vw, 56px);
    }
    .spec-row {
      gap: 2px;
      padding: 10px 0;
    }
    .spec-k {
      font-size: 11px;
      letter-spacing: 0.15em;
    }
    .spec-v {
      font-size: 17px;
    }
  }
</style>
