---
const links = [
  { href: "#services", label: "Услуги" },
  { href: "#projects", label: "Кейсы" },
  { href: "#partners-c", label: "Партнеры" },
  { href: "#process", label: "Процесс" },
  { href: "#specs", label: "Параметры" },
  { href: "#cta", label: "Контакты" },
];
---

<header class="nav" id="nav">
  <div class="nav-logo">
    <img src="/assets/logo-text.png" alt="АДДИТЕХПРОММАШ" />
  </div>
  <nav class="nav-links">
    {links.map(({ href, label }) => <a href={href}>{label}</a>)}
  </nav>
  <div class="nav-phones">
    <a href="tel:+79910979059" class="nav-phone">+7 (991) 097-90-59</a>
    <a href="tel:+79060554525" class="nav-phone">+7 (906) 055-45-25</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--pad);
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition:
      background 0.15s,
      border-color 0.15s;
    --nav-fg: rgba(255, 255, 255, 0.9);
  }
  .nav.on {
    background: rgba(206, 206, 206, 0.7);
    backdrop-filter: blur(20px);
    border-color: rgba(0, 0, 0, 0.1);
    --nav-fg: #000;
  }
  .nav-logo {
    display: flex;
    align-items: center;
  }
  .nav-logo img {
    height: 36px;
    width: auto;
    filter: brightness(0) invert(1);
    transition: filter 0.15s;
  }
  .nav.on .nav-logo img {
    filter: brightness(0);
  }
  .nav-links {
    display: flex;
    gap: clamp(14px, 1.8vw, 28px);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--nav-fg);
    transition: color 0.15s;
  }
  .nav-links a {
    transition: color 0.15s;
    color: inherit;
  }
  .nav-links a:hover {
    color: var(--orange);
  }
  .nav-phones {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: right;
    flex-shrink: 1;
    min-width: 0;
  }
  .nav-phone {
    font-family: inherit;
    font-weight: 500;
    font-size: clamp(14px, min(0.75vw, 1.1svh), 16px);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--nav-fg);
    transition: color 0.15s;
    line-height: 1.15;
    white-space: nowrap;
  }
  .nav-phone:hover {
    color: var(--orange);
  }

  /* Tablets + phones: hide section nav — only logo (+ phones on tablet) */
  @media (max-width: 1199px) {
    .nav-links {
      display: none;
    }
  }
  /* Phones only: hide phone numbers too */
  @media (max-width: 767px) {
    .nav-phones {
      display: none;
    }
  }
</style>
