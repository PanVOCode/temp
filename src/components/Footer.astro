        <p class="ft-full">ООО «НПК «АДДИТЕХПРОММАШ»</p>
      </div>

      <!-- Contacts -->
      <div class="ft-col">
        <h3 class="ft-col-label">Контакты</h3>
        <ul class="ft-list">
          <li><a href="tel:+79910979059" class="ft-link">+7 (991) 097-90-59</a></li>
          <li><a href="tel:+79060554525" class="ft-link">+7 (906) 055-45-25</a></li>
          <li><a href="mailto:additechprommash@yandex.ru" class="ft-link">additechprommash@yandex.ru</a></li>
