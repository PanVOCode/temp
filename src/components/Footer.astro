</footer>

<style>
  .site-footer {
    background: #F3F3F3;
    border-top: 1px solid #000;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1.5fr 1fr;
    gap: 0;
    border-bottom: 1px solid rgba(0,0,0,0.12);
    padding: clamp(40px, 5vw, 72px) 0;
  }
  .ft-brand {
    padding-right: clamp(24px, 3vw, 48px);
    border-right: 1px solid rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ft-logo {
    font-family: var(--font);
    font-weight: 800;
    font-size: clamp(20px, 2.5vw, 28px);
    letter-spacing: -0.02em;
    color: #000;
    line-height: 1.1;
    text-transform: uppercase;
    max-width: 200px;
  }
  .ft-tagline {
    font-family: var(--font);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }
  .ft-full {
    font-family: var(--font);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    margin: 0;
  }

  .ft-col {
    padding: 0 clamp(16px, 2vw, 32px);
    border-right: 1px solid rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ft-col:last-child { border-right: none; }
  .ft-col-label {
    font-family: var(--font);
    font-weight: 800;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .ft-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ft-link {
    font-family: var(--font);
    font-weight: 400;
    font-size: 13px;
    color: #333;
    text-decoration: none;
    transition: color 0.2s;
  }
  .ft-link:hover { color: #FF6A00; }
  .ft-muted {
    font-family: var(--font);
    font-weight: 400;
    font-size: 12px;
    color: #888;
  }

  .ft-legal {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .fl-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    gap: 8px;
  }
  .fl-k {
    font-family: var(--font);
    font-weight: 500;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #aaa;
  }
  .fl-v {
    font-family: var(--font);
    font-weight: 500;
    font-size: 12px;
    color: #333;
  }

  .ft-socials {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ft-social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font);
    font-weight: 500;
    font-size: 12px;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .ft-social-link:hover { color: #FF6A00; }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    gap: 16px;
    flex-wrap: wrap;
  }
  .fb-copy {
    font-family: var(--font);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #999;
  }
  .fb-site {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #999;
  }
  .fb-dot {
    width: 5px; height: 5px;
    background: #FF6A00;
    border-radius: 50%;
    animation: fbPulse 2.5s ease-in-out infinite;
  }
  @keyframes fbPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @media (max-width: 1024px) {
    .footer-top { grid-template-columns: 1fr 1fr; gap: 0; }
    .ft-brand { border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 24px; margin-bottom: 0; grid-column: 1/-1; border-right: none; }
    .ft-col:nth-child(3) { border-right: none; }
  }
  @media (max-width: 600px) {
    .footer-top { grid-template-columns: 1fr; }
    .ft-col { border-right: none; border-bottom: 1px solid rgba(0,0,0,0.08); padding: 24px 0; }
    .ft-col:last-child { border-bottom: none; }
  }
</style>
