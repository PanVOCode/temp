          <div class="fl-row"><span class="fl-k">ИНН</span><span class="fl-v">7733472230</span></div>
          <div class="fl-row"><span class="fl-k">ОГРН</span><span class="fl-v">1257700330403</span></div>
          <div class="fl-row"><span class="fl-k">КПП</span><span class="fl-v">773301001</span></div>
          <div class="fl-row"><span class="fl-k">Статус</span><span class="fl-v" style="color:#FF6A00;">Действует</span></div>
