      <!-- Social -->
      <div class="ft-col">
        <h3 class="ft-col-label">Мессенджеры</h3>
        <div class="ft-socials">
          <a href="https://t.me/Alexandr_Semenets" target="_blank" rel="noopener noreferrer" class="ft-social-link">
