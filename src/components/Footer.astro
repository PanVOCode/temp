            @Alexandr_Semenets
          </a>
          <a href="https://t.me/ganucorl" target="_blank" rel="noopener noreferrer" class="ft-social-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M21.5 4.5L2.5 12l5 2 2 6 3-4 5 4 4-15.5z"/></svg>
            @ganucorl
          </a>
          <a href="https://wa.me/79910979059" target="_blank" rel="noopener noreferrer" class="ft-social-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.3A10 10 0 1 0 12 2zm5.6 14.2c-.2.6-1.2 1.2-1.7 1.2-.4 0-1 .1-1.6-.1-.4-.1-1-.3-1.6-.6-2.8-1.2-4.7-4.1-4.8-4.3-.1-.2-1.1-1.5-1.1-2.9 0-1.4.7-2 1-2.3.3-.3.6-.4.8-.4h.6c.2 0 .5 0 .7.5l1 2.3c.1.2.1.4 0 .6l-.4.5c-.1.2-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1l.8-.9c.2-.2.4-.2.6-.1l2.1 1c.2.1.4.2.4.3 0 .3 0 .9-.2 1.4z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom strip -->
    <div class="footer-bottom">
      <span class="fb-copy">© {year} АДДИТЕХПРОММАШ. Все права защищены.</span>
      <span class="fb-site">
        <span class="fb-dot"></span>
        additechprom.ru · Российское производство
      </span>
    </div>
