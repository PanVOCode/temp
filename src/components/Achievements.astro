---
---

<!-- PANEL: О КОМПАНИИ — photo left, text right -->
<section id="about" class="about-panel">

  <div class="abt-photo">
    <img src="/photo-mold-industrial.png" alt="Пресс-форма АДДИТЕХПРОММАШ" class="abt-img" loading="lazy">
    <span class="abt-ghost" aria-hidden="true">02</span>
  </div>

  <div class="abt-text" data-reveal>
    <div class="abt-inner">

      <div class="sw-label">01 / КОМПАНИЯ</div>

      <h2 class="abt-title">
        <span class="abt-line">АДДИТЕХ</span>
        <span class="abt-line abt-outline">ПРОММАШ</span>
      </h2>

      <div class="sw-rule"></div>

      <div class="sw-specs">
        <div class="sw-row">
          <span class="sw-k">Деятельность</span>
          <span class="sw-v">Пресс-формы любой сложности и конфигурации</span>
        </div>
        <div class="sw-row">
          <span class="sw-k">Офис · Производство</span>
          <span class="sw-v">Москва · г. Владимир</span>
        </div>
        <div class="sw-row">
          <span class="sw-k">Технологии</span>
          <span class="sw-v">DMLS · SLM · ЧПУ · FDM</span>
        </div>
        <div class="sw-row">
          <span class="sw-k">Проектов</span>
          <span class="sw-v">30+ успешно введены в эксплуатацию</span>
        </div>
        <div class="sw-row">
          <span class="sw-k">Инженеров</span>
          <span class="sw-v">15 специалистов</span>
        </div>
      </div>

      <div class="abt-metrics-row">
        <div class="abt-metric">
          <span class="abt-m-val">−25%</span>
          <span class="abt-m-lab">vs импорт</span>
        </div>
        <div class="abt-metric-div"></div>
        <div class="abt-metric">
          <span class="abt-m-val">3 нед.</span>
          <span class="abt-m-lab">средний срок</span>
        </div>
      </div>

    </div>
  </div>

</section>

<style>
  .about-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    border-bottom: 1px solid #000;
  }

  /* Foreground effect: contain oversized → деталь целиком + блид вправо */
  .abt-photo {
    position: relative;
    background: #060606;
    overflow: visible;
    border-right: 1px solid #000;
    order: 1;
    z-index: 10;
  }
  .abt-img {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 130%;
    height: 140%;
    object-fit: contain;
    object-position: center;
    z-index: 10;
  }
  .abt-ghost {
    position: absolute;
    bottom: -0.1em;
    right: -0.04em;
    font-family: var(--font);
    font-weight: 800;
    font-stretch: expanded;
    font-size: clamp(160px, 22vw, 340px);
    letter-spacing: -0.05em;
    line-height: 1;
    color: rgba(0,0,0,0.04);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* Text — RIGHT, under photo bleed */
  .abt-text {
    order: 2;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .abt-inner {
    padding: clamp(48px, 7vw, 100px) clamp(40px, 5vw, 80px);
    width: 100%;
  }

  .sw-label {
    font-family: var(--font);
    font-weight: 400;
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .sw-label::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: #999;
    flex-shrink: 0;
  }

  .abt-title {
    display: flex;
    flex-direction: column;
    margin: 0 0 32px;
    line-height: 0.88;
  }
  .abt-line {
    font-family: var(--font);
    font-weight: 800;
    font-stretch: expanded;
    font-size: clamp(52px, 7.5vw, 100px);
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: #000;
    text-transform: uppercase;
    display: block;
  }
  .abt-outline {
    -webkit-text-stroke: 2px #000;
    color: transparent;
  }

  .sw-rule {
    height: 1px;
    background: #000;
    margin-bottom: 28px;
  }

  .sw-specs {
    display: flex;
    flex-direction: column;
    margin-bottom: 40px;
  }
  .sw-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 11px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    gap: 16px;
  }
  .sw-k {
    font-family: var(--font);
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
    flex-shrink: 0;
  }
  .sw-v {
    font-family: var(--font);
    font-weight: 500;
    font-size: 12px;
    color: #000;
    text-align: right;
  }

  .abt-metrics-row {
    display: flex;
    align-items: stretch;
    gap: 0;
    padding-top: 24px;
    border-top: 2px solid #FF6A00;
  }
  .abt-metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .abt-metric-div {
    width: 1px;
    background: rgba(0,0,0,0.12);
    margin: 0 24px;
  }
  .abt-m-val {
    font-family: var(--font);
    font-weight: 800;
    font-size: clamp(32px, 4.5vw, 60px);
    letter-spacing: -0.04em;
    color: #FF6A00;
    line-height: 1;
  }
  .abt-m-lab {
    font-family: var(--font);
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
  }

  @media (max-width: 768px) {
    .about-panel { grid-template-columns: 1fr; }
    .abt-photo { min-height: 55vh; order: 1; border-right: none; border-bottom: 1px solid #000; }
    .abt-text { order: 2; }
  }
</style>
