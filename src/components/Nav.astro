---
const navLinks = [
  { label: 'О компании', href: '#about' },
  { label: 'Процесс', href: '#process' },
  { label: 'Контакты', href: '#contact' },
];
const phone = '+7 (991) 097-90-59';
const phoneHref = 'tel:+79910979059';
---

<header class="atpm-nav" id="atpm-nav">
  <div class="atpm-nav-inner cx">
    <a href="#" class="atpm-logo" aria-label="АДДИТЕХПРОММАШ — главная">
      <span class="atpm-logo-dot" aria-hidden="true"></span>
      <span class="atpm-logo-mark">АДДИТЕХ<wbr>ПРОММАШ</span>
    </a>

    <nav class="atpm-nav-links" aria-label="Основная навигация">
      {navLinks.map((l) => (
        <a href={l.href} class="atpm-nav-link">{l.label}</a>
      ))}
    </nav>

    <div class="atpm-nav-right">
      <a href={phoneHref} class="atpm-nav-phone">{phone}</a>
      <a href={phoneHref} class="btn-atpm atpm-nav-cta">
        <span>Позвонить</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <button type="button" id="nav-toggle" class="atpm-nav-burger" aria-label="Меню" aria-expanded="false">
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>
  </div>

  <div id="nav-mobile" class="atpm-nav-mobile hidden">
    <nav class="cx" aria-label="Мобильная навигация">
      {navLinks.map((l) => (
        <a href={l.href} class="atpm-mobile-link">{l.label}</a>
      ))}
      <a href={phoneHref} class="atpm-mobile-phone">{phone}</a>
    </nav>
  </div>
</header>

<style>
  .atpm-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: rgba(243,243,243,0.88);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border-bottom: 1px solid rgba(0,0,0,0.18);
    transition: background 0.3s;
  }
  .atpm-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 40px;
  }
  .atpm-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .atpm-logo-dot {
    display: block;
    width: 6px;
    height: 6px;
    background: #FF6A00;
    flex-shrink: 0;
  }
  .atpm-logo-mark {
    font-family: var(--font);
    font-weight: 800;
    font-size: 15px;
    letter-spacing: -0.01em;
    color: #000;
    line-height: 1;
    text-transform: uppercase;
  }
  .atpm-nav-links {
    display: flex;
    align-items: center;
    gap: 40px;
    flex: 1;
    justify-content: center;
  }
  .atpm-nav-link {
    font-family: var(--font);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #111;
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
  }
  .atpm-nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px; right: 0;
    height: 1px;
    background: #FF6A00;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.16,1,0.3,1);
  }
  .atpm-nav-link:hover::after { transform: scaleX(1); }
  .atpm-nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }
  .atpm-nav-phone {
    font-family: var(--font);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.05em;
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }
  .atpm-nav-phone:hover { color: #000; }
  .atpm-nav-cta {
    padding: 10px 20px;
    font-size: 10px;
  }
  .atpm-nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: 1px solid #000;
    padding: 8px 10px;
    cursor: pointer;
  }
  .burger-line {
    display: block;
    width: 18px;
    height: 1px;
    background: #000;
  }

  /* Mobile */
  .atpm-nav-mobile {
    border-top: 1px solid rgba(0,0,0,0.15);
    background: #F3F3F3;
    padding: 24px 0;
  }
  .atpm-nav-mobile nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .atpm-mobile-link {
    font-family: var(--font);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #000;
    padding: 14px 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    text-decoration: none;
  }
  .atpm-mobile-phone {
    font-family: var(--font);
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: #666;
    padding: 14px 0;
    text-decoration: none;
    display: block;
  }

  @media (max-width: 900px) {
    .atpm-nav-links { display: none; }
    .atpm-nav-phone { display: none; }
    .atpm-nav-cta { display: none; }
    .atpm-nav-burger { display: flex; }
  }
</style>

<script is:inline>
  (function() {
    var btn = document.getElementById('nav-toggle');
    var panel = document.getElementById('nav-mobile');
    if (!btn || !panel) return;
    btn.addEventListener('click', function() {
      var open = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
    });
    panel.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        panel.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
