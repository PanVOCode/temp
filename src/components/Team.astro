---
// Marquee ticker strip between Hero and About
const items = [
  'ПРОЕКТИРОВАНИЕ ПРЕСС-ФОРМ',
  'ПРОИЗВОДСТВО ПРЕСС-ФОРМ',
  'МЕЛКОСЕРИЙНОЕ И КРУПНОСЕРИЙНОЕ ЛИТЬЁ',
  'МЕТАЛЛООБРАБОТКА',
  'РАЗРАБОТКА КД ПО ЕСКД',
  'АДДИТИВНЫЕ ТЕХНОЛОГИИ',
  'DMLS · SLM · FDM',
  'СРОКИ — НЕДЕЛИ, НЕ МЕСЯЦЫ',
  'ДЕШЕВЛЕ КИТАЯ',
  'ВЛАДИМИР · РОССИЯ',
];
// Duplicate for seamless loop
const all = [...items, ...items];
---

<div class="ticker" aria-hidden="true">
  <div class="marquee-outer">
    <div class="marquee-inner">
      {all.map((item) => (
        <span class="ticker-item">
          {item}<span class="ticker-sep">·</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .ticker {
    background: #000;
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
    height: 46px;
    overflow: hidden;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    font-family: var(--font);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    padding: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ticker-sep {
    font-size: 12px;
    color: #FF6A00;
    opacity: 0.7;
    margin: 0 8px;
  }
</style>
